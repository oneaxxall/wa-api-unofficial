# ============================================================
# WAUN — WhatsApp Unofficial Gateway
# Environment Configuration
# ============================================================
# Copy file ini: cp .env.example .env
# Lalu edit sesuai kebutuhan.
# ============================================================

# ============================================================
# SERVER — Konfigurasi dasar HTTP server
# ============================================================

# Port dimana HTTP server akan mendengarkan request
PORT=3008

# Bind address. 0.0.0.0 = semua interface (docker-friendly)
HOST=0.0.0.0

# Environment mode: development | production
# - development: auto-restart, pretty logs, http:// webhook diizinkan
# - production:  json logs, https:// wajib untuk webhook
NODE_ENV=development

# ============================================================
# LOGGING — Kontrol output log
# ============================================================

# Debug mode: 0 = info level, 1 = debug level (verbose)
# DEBUG=1 akan override LOG_LEVEL dan menampilkan log detail
DEBUG=0

# Level log: trace | debug | info | warn | error | fatal
# (Ter-override ke debug kalau DEBUG=1)
LOG_LEVEL=info

# Format log: pretty (warna, human-readable) | json (production)
LOG_FORMAT=pretty

# ============================================================
# CORS — Cross-Origin Resource Sharing
# ============================================================

# Whitelist origin yang diizinkan akses API (pisah pake koma)
# Contoh: CORS_ORIGINS=http://app.example.com,https://admin.example.com
# Kosongkan kalau mau same-origin only (paling aman)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# IP WHITELIST — Batasi akses ke IP tertentu (OPSIONAL)
# ============================================================

# Format: IP atau CIDR, pisah pake koma
# Contoh: IP_WHITELIST=192.168.1.1,10.0.0.0/24,203.0.113.0/24
# Kosongkan = semua IP diizinkan (default)
IP_WHITELIST=

# ============================================================
# DATABASE — SQLite configuration
# ============================================================

# Path file database SQLite
DB_PATH=./data/waun.db

# Folder untuk backup database otomatis
DB_BACKUP_DIR=./data/backups

# ============================================================
# SESSION — WhatsApp session storage
# ============================================================

# Folder penyimpanan session WhatsApp (creds.json untuk Baileys,
# atau Chrome profile untuk whatsapp-web.js)
SESSION_DIR=./sessions

# ============================================================
# AUTH — Autentikasi API
# ============================================================

# Master API key — bisa akses SEMUA endpoint (override per-account key)
# Kosongkan = nonaktif (hanya per-account key yang berlaku)
API_SECRET_KEY_ADMIN=admin-waun-key-123

# ============================================================
# WHATSAPP LIBRARY — Pilih backend WhatsApp
# ============================================================

# Library yang dipake: baileys (default) | wwebjs
# - baileys: WebSocket murni, tanpa Chrome, RAM 5-10 MB/akun ✅
# - wwebjs:  whatsapp-web.js (Puppeteer + Chromium), RAM 150-250 MB/akun
WA_LIBRARY=baileys

# Versi WhatsApp Web (hanya untuk WA_LIBRARY=wwebjs)
# Biarkan kosong kalau pake Baileys (tidak relevan)
# WEB_VERSION=2.3000.1019783070

# Path ke binary Google Chrome/Chromium (hanya untuk WA_LIBRARY=wwebjs)
# Biarkan kosong kalau pake Baileys (tidak perlu Chrome)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# ============================================================
# ANTI-BAN — Proteksi dari pemblokiran WhatsApp
# ============================================================
# Lihat docs/ANTI-BAN.md untuk panduan lengkap tuning.
# Default value aman untuk 1 akun dengan aktivitas normal.
# ============================================================

# Delay MINIMAL antar pengiriman pesan (milidetik)
# Terlalu cepat → kena banned. 3 detik minimal aman.
AB_MIN_DELAY=3000

# Delay MAKSIMAL antar pengiriman pesan (milidetik)
# Range delay acak: AB_MIN_DELAY - AB_MAX_DELAY
AB_MAX_DELAY=12000

# Jitter factor: tambah variasi acak ±30% dari delay
# Biar pola kirim gak kelihatan bot (detected by WhatsApp)
AB_JITTER_FACTOR=0.3

# MAKSIMAL pesan per akun per HARI
# Setelah mencapai limit, broadcast akan pause otomatis
# Lanjut lagi besok setelah reset (lihat AB_RESET_HOUR)
AB_DAILY_LIMIT=500

# Jam RESET daily counter (format 24 jam)
# Default jam 3 pagi — aktivitas paling rendah
AB_RESET_HOUR=3

# MAKSIMAL pesan ke KONTAK YANG SAMA per hari
# Cegah spam ke satu nomor — biar gak di-block kontak
AB_MAX_PER_CONTACT=50

# ============================================================
# WARMUP — Gradual volume increase untuk akun baru
# ============================================================
# Akun baru langsung kirim 500/hari? WhatsApp curiga.
# Warmup naikin limit bertahap selama N hari.
# ============================================================

# Lama warmup (hari). Setelah N hari, limit = AB_DAILY_LIMIT penuh.
AB_WARMUP_DAYS=7

# Persentase limit di HARI PERTAMA warmup
# Contoh: AB_DAILY_LIMIT=500, multiplier=0.3 → hari-1 cuma 150
AB_WARMUP_MULTIPLIER=0.3

# ============================================================
# BROADCAST — Konfigurasi pengiriman massal
# ============================================================

# Maksimal kontak dalam SATU broadcast request
# Kirim 100.001 kontak? Pecah jadi 11+ request
BROADCAST_MAX_CONTACTS=10000

# ============================================================
# QUEUE — BullMQ (Redis-based job queue, OPSIONAL)
# ============================================================
# Aktifkan kalau mau broadcast yang lebih reliable.
# Butuh Redis server. Kalau gak ada Redis, broadcast tetap jalan
# pake setImmediate biasa (inline processing).
# ============================================================

# Aktifkan queue: true | false
QUEUE_ENABLED=true

# Redis connection — hanya dipake kalau QUEUE_ENABLED=true
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============================================================
# AUTO-RECONNECT — Recovery ketika koneksi putus
# ============================================================

# Maksimal percobaan reconnect otomatis
# Kalau koneksi putus karena network glitch, WAUN coba reconnect
# Kalau logout/expired — gak di-reconnect (wajib scan QR ulang)
RECONNECT_MAX_ATTEMPTS=3

# Delay antar percobaan reconnect (milidetik)
RECONNECT_DELAY=5000

# ============================================================
# GRACEFUL SHUTDOWN — Penutupan server yang aman
# ============================================================

SHUTDOWN_TIMEOUT=40000
SHUTDOWN_BROADCAST_TIMEOUT=30000

# ============================================================
# QUICK QR — QR pairing tanpa akun (OPSIONAL)
# ============================================================

# Timeout QR code dalam ms. Default 120000 (1 menit)
QR_TEMP_TTL=120000
