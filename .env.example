# ============================================================
# WAUN — WhatsApp Unofficial Gateway
# Example Environment Configuration
# ============================================================
# Copy file ini: cp .env.example .env
# Lalu edit sesuai kebutuhan.
# ============================================================

# ============================================================
# SERVER — Konfigurasi dasar HTTP server
# ============================================================

PORT=3008
HOST=0.0.0.0
NODE_ENV=development

# ============================================================
# LOGGING — Kontrol output log
# ============================================================

# DEBUG=1 override log level ke debug (verbose)
DEBUG=0
LOG_LEVEL=info
LOG_FORMAT=pretty

# ============================================================
# CORS — Cross-Origin Resource Sharing
# ============================================================

# Whitelist origin (pisah pake koma). Kosongkan = same-origin.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# IP WHITELIST — Batasi akses ke IP tertentu (OPSIONAL)
# ============================================================

# Format: IP atau CIDR, pisah pake koma. Kosongkan = semua IP.
IP_WHITELIST=

# ============================================================
# DATABASE — SQLite
# ============================================================

DB_PATH=./data/waun.db
DB_BACKUP_DIR=./data/backups

# ============================================================
# SESSION — WhatsApp session storage
# ============================================================

SESSION_DIR=./sessions

# ============================================================
# WHATSAPP LIBRARY — baileys (default) | wwebjs
# ============================================================

WA_LIBRARY=baileys
# WEB_VERSION=2.3000.1019783070
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# ============================================================
# ANTI-BAN — Proteksi pemblokiran
# ============================================================

AB_MIN_DELAY=3000
AB_MAX_DELAY=12000
AB_JITTER_FACTOR=0.3
AB_DAILY_LIMIT=500
AB_RESET_HOUR=3
AB_MAX_PER_CONTACT=50

# ============================================================
# WARMUP — Gradual volume untuk akun baru
# ============================================================

AB_WARMUP_DAYS=7
AB_WARMUP_MULTIPLIER=0.3

# ============================================================
# BROADCAST — Pengiriman massal
# ============================================================

BROADCAST_MAX_CONTACTS=10000

# ============================================================
# QUEUE — BullMQ (opsional, butuh Redis)
# ============================================================

QUEUE_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================
# AUTO-RECONNECT
# ============================================================

RECONNECT_MAX_ATTEMPTS=3
RECONNECT_DELAY=5000

# ============================================================
# GRACEFUL SHUTDOWN
# ============================================================

SHUTDOWN_TIMEOUT=40000
SHUTDOWN_BROADCAST_TIMEOUT=30000
